<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_presets"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@android:drawable/ic_menu_revert" />

    </com.google.android.material.appbar.AppBarLayout>

    <TextView
        android:id="@+id/tv_category_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="8dp"
        android:text="Categoría"
        android:textAppearance="@style/TextAppearance.App.HeadlineMedium"
        android:textColor="@color/color_primary"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/btnGoogleFit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGoogleFit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Google Fit"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/color_primary"
        android:clickable="false"
        android:focusable="false"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:minWidth="0dp"
        app:icon="@drawable/ic_google"
        app:iconGravity="textStart"
        app:iconTint="@color/color_primary"
        app:iconPadding="6dp"
        app:iconSize="16dp"
        android:backgroundTint="@color/color_surface"
        app:backgroundTint="@color/color_surface"
        app:strokeWidth="1dp"
        app:strokeColor="@color/color_primary"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_category_name" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_presets"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_category_name"
        tools:listitem="@layout/item_preset" />

</androidx.constraintlayout.widget.ConstraintLayout>