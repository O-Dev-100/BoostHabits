<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="160dp"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="12dp">

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.App.Card.Habit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_habit"
            android:padding="16dp">

            <RelativeLayout
                android:id="@+id/top_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tv_habit_icon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_alignParentStart="true"
                    android:background="@drawable/bg_economy_chip"
                    android:gravity="center"
                    android:text="🏃"
                    android:textSize="24sp" />

                <ImageButton
                    android:id="@+id/btn_delete_habit"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="?attr/colorError" />

                <TextView
                    android:id="@+id/tv_habit_streak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/btn_delete_habit"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_economy_chip"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="🔥 0"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <TextView
                android:id="@+id/tv_habit_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:minLines="2"
                android:text="Caminar"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/top_layout" />

            <LinearLayout
                android:id="@+id/layout_reward"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_habit_name">

                <ImageView
                    android:id="@+id/iv_reward_icon"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_monedas"
                    app:tint="?attr/colorSecondary" />

                <TextView
                    android:id="@+id/tv_habit_reward_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="+50"
                    android:textColor="?attr/colorSecondary"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_activity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:indicatorColor="?attr/colorSecondary"
                app:trackColor="#1A000000"
                app:trackCornerRadius="4dp"
                app:layout_constraintTop_toBottomOf="@id/layout_reward"
                tools:progress="60"
                tools:visibility="visible" />

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/lottie_loading"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                app:lottie_rawRes="@raw/loading_sync"
                app:layout_constraintTop_toBottomOf="@id/progress_activity"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tv_timer_countdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="00:00"
                android:textAlignment="center"
                android:textColor="?attr/colorPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/lottie_loading" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_completar"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingVertical="4dp"
                android:text="Completar"
                android:textSize="11sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:layout_constraintTop_toBottomOf="@id/tv_timer_countdown" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Botón de Focus fuera de la card (elevado) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_focus"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_gravity="top|start"
        android:paddingHorizontal="12dp"
        android:visibility="gone"
        app:icon="@drawable/ic_zen"
        app:iconSize="20dp"
        app:iconTint="#FFFFFF"
        android:text="Focus"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        app:iconGravity="textStart"
        app:backgroundTint="#008080"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
        android:elevation="12dp"
        android:translationZ="8dp"
        tools:visibility="visible" />

</FrameLayout>