<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_category"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/color_surface"
        app:cardCornerRadius="24dp"
        app:cardElevation="1dp"
        app:strokeColor="@color/color_primary_container"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/bg_gradient_light_blue"
            android:padding="20dp">

            <TextView
                android:id="@+id/tv_categoria_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏃"
                android:textSize="44sp"
                app:layout_constraintBottom_toTopOf="@id/tv_category_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <ImageView
                android:id="@+id/iv_category_icon_drawable"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:visibility="gone"
                app:layout_constraintBottom_toTopOf="@id/tv_category_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/tv_category_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Categoría"
                android:textAppearance="@style/TextAppearance.App.TitleMedium"
                android:textColor="@color/color_primary"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_categoria_icon" />

            <ImageView
                android:id="@+id/iv_gem_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_margin="4dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_gemas" />

            <ImageView
                android:id="@+id/iv_zen_icon_category"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_margin="4dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_zen"
                app:tint="@color/color_primary" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Burbuja Focus informativa (solo para Salud Mental) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_focus_badge"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="2dp"
        android:layout_marginTop="2dp"
        android:minWidth="64dp"
        android:paddingHorizontal="12dp"
        android:visibility="gone"
        app:icon="@drawable/ic_zen"
        app:iconSize="18dp"
        app:iconTint="#FFFFFF"
        android:text="@string/home_focus_label"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        app:iconGravity="textStart"
        app:backgroundTint="#008080"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
        android:elevation="6dp"
        android:translationZ="4dp"
        android:clickable="false"
        android:focusable="false" />

</FrameLayout>