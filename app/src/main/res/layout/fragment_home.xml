<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">


    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- HEADER / SALUDO -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/avatar"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@mipmap/ic_launcher_round"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="2dp" />

            <TextView
                android:id="@+id/tv_saludo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/home_welcome"
                android:textColor="?attr/colorOnBackground"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/tv_sub_saludo"
                app:layout_constraintEnd_toStartOf="@id/economy_container"
                app:layout_constraintStart_toEndOf="@id/avatar"
                app:layout_constraintTop_toTopOf="@id/avatar"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/tv_sub_saludo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Tu progreso hoy va genial"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="@id/avatar"
                app:layout_constraintEnd_toEndOf="@id/tv_saludo"
                app:layout_constraintStart_toStartOf="@id/tv_saludo"
                app:layout_constraintTop_toBottomOf="@id/tv_saludo" />

            <LinearLayout
                android:id="@+id/economy_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:id="@+id/gems_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_economy_chip"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_gemas" />

                    <TextView
                        android:id="@+id/tv_gems_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="0"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/coins_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_economy_chip"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_monedas" />

                    <TextView
                        android:id="@+id/tv_coins_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="0"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- HÁBITOS POR COMPLETAR (EN ESPERA) -->
            <TextView
                android:id="@+id/titulo_en_espera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/home_habits_waiting"
                android:textColor="?attr/colorOnBackground"
                android:textSize="20sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_sub_saludo" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_habitos_espera"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:visibility="gone"
                android:layoutAnimation="@anim/layout_animation_fall_down"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/titulo_en_espera"
                tools:listitem="@layout/item_habit_home" />

            <!-- VIEW PAGER PARA CARDS DE ESTADÍSTICAS -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vp_stats_cards"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/rv_habitos_espera" />

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tl_stats_indicator"
                android:layout_width="wrap_content"
                android:layout_height="12dp"
                android:layout_marginTop="12dp"
                android:background="@android:color/transparent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/vp_stats_cards"
                app:tabBackground="@drawable/selector_tab_indicator"
                app:tabIndicatorHeight="0dp"
                app:tabMaxWidth="12dp"
                app:tabRippleColor="@null" />

            <!-- RESUMEN EN FILA -->
            <LinearLayout
                android:id="@+id/resumen_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/tl_stats_indicator">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_gradient_light_blue"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tv_racha_valor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔥 0"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/home_racha"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_gradient_light_blue"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tv_habitos_conteo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✅ 0"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/home_today"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- TUS HÁBITOS SECCIÓN DINÁMICA -->
            <TextView
                android:id="@+id/titulo_tus_habitos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="@string/home_habits"
                android:textColor="?attr/colorOnBackground"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/resumen_row" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_habitos_hoy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:layoutAnimation="@anim/layout_animation_fall_down"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintTop_toBottomOf="@id/titulo_tus_habitos"
                tools:listitem="@layout/item_habit_home" />

            <!-- PLACEHOLDER HÁBITOS VACÍOS -->
            <LinearLayout
                android:id="@+id/layout_empty_habits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/titulo_tus_habitos">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨"
                    android:textSize="64sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/home_empty_title"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/home_empty_desc"
                    android:textAlignment="center"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- RECOMENDACIONES -->
            <TextView
                android:id="@+id/titulo_sugeridos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="@string/home_recommendations"
                android:textColor="?attr/colorOnBackground"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/barrier_tus_habitos" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrier_tus_habitos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="rv_habitos_hoy,layout_empty_habits" />

            <FrameLayout
                android:id="@+id/card_focus_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                app:layout_constraintTop_toBottomOf="@id/titulo_sugeridos">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_sugerida_home"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorPrimaryContainer"
                    app:cardElevation="2dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_gradient_light_blue"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tv_emoji_sug1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🧠"
                            android:textSize="36sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tv_title_sug1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="@string/home_mental_health"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toStartOf="@id/btn_ver_categorias"
                            app:layout_constraintStart_toEndOf="@id/tv_emoji_sug1"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/home_mental_health_desc"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="13sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/btn_ver_categorias"
                            app:layout_constraintStart_toStartOf="@id/tv_title_sug1"
                            app:layout_constraintTop_toBottomOf="@id/tv_title_sug1" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_ver_categorias"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_explore"
                            android:textColor="?attr/colorPrimary"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Burbuja Focus -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_focus_mental"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_gravity="top|start"
                    android:paddingHorizontal="12dp"
                    app:icon="@drawable/ic_zen"
                    app:iconSize="20dp"
                    app:iconTint="#FFFFFF"
                    android:text="@string/home_focus_label"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    app:iconGravity="textStart"
                    app:backgroundTint="#008080"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                    android:elevation="12dp"
                    android:translationZ="8dp" />

            </FrameLayout>


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_sugerida_home_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="24dp"
                app:layout_constraintTop_toBottomOf="@id/card_focus_container"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorPrimaryContainer"
                app:cardElevation="2dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_gradient_light_blue"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tv_emoji_sug2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥗"
                        android:textSize="36sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_title_sug2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="@string/home_nutrition"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/btn_ver_nutricion"
                        app:layout_constraintStart_toEndOf="@id/tv_emoji_sug2"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/home_nutrition_desc"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/btn_ver_nutricion"
                        app:layout_constraintStart_toStartOf="@id/tv_title_sug2"
                        app:layout_constraintTop_toBottomOf="@id/tv_title_sug2" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_ver_nutricion"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_explore"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_sugerida_home_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="24dp"
                app:layout_constraintTop_toBottomOf="@id/card_sugerida_home_2"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorPrimaryContainer"
                app:cardElevation="2dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_gradient_light_blue"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tv_emoji_sug3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏠"
                        android:textSize="36sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_title_sug3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="@string/home_home_habits"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/btn_ver_hogar"
                        app:layout_constraintStart_toEndOf="@id/tv_emoji_sug3"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/home_home_habits_desc"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/btn_ver_hogar"
                        app:layout_constraintStart_toStartOf="@id/tv_title_sug3"
                        app:layout_constraintTop_toBottomOf="@id/tv_title_sug3" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_ver_hogar"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_explore"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- OVERLAY PARA ANIMACIONES DE ÉXITO -->
    <FrameLayout
        android:id="@+id/lottie_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1A000000"
        android:visibility="gone">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottie_success_main"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:lottie_autoPlay="false"
            app:lottie_loop="false" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
