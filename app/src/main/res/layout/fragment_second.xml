<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:padding="16dp"
    tools:context="com.boosthabits.SecondFragment">

    <TextView
        android:id="@+id/textTituloPlaceholder"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Pantalla secundaria"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/color_on_background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/textDescripcionPlaceholder"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Esta pantalla se utilizará más adelante para navegación interna (por ejemplo, detalles de hábitos o estadísticas)."
        android:textSize="14sp"
        android:textColor="@color/color_on_background"
        app:layout_constraintTop_toBottomOf="@id/textTituloPlaceholder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>